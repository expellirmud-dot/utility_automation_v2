# Environment Template for Core Autonomous Governance Stack
# Copy this file to .env

# General
LOG_LEVEL=INFO
INTERNAL_SERVICE_TOKEN=your_shared_secret_token_here

# Storage
DB_PATH=data/utility_automation_v2.db
LEDGER_PATH=ledger/events.log

# AI Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=models/gemini-3.1-flash-live-preview

# Service URLs (Containerized)
IDENTITY_URL=http://gov-identity:8002
RULES_URL=http://gov-rules:8003
AUDIT_URL=http://gov-audit:8001
CONTROL_URL=http://gov-control:8000
